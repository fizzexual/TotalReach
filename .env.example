# Copy this file to .env and adjust values.

# SQLite database location (relative to the prisma/ folder)
DATABASE_URL="file:./dev.db"

# Secret used to sign session JWTs. Generate a strong random value for production, e.g.:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
AUTH_SECRET="change-me-to-a-long-random-string"

# Email (SMTP) — required to send real emails from automations.
# Gmail: host smtp.gmail.com, port 587, user = your address,
# pass = a 16-char Google "App Password" (https://myaccount.google.com/apppasswords).
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
EMAIL_FROM="TotalReach <no-reply@example.com>"

# Public base URL for email open-tracking pixels.
APP_URL="http://localhost:3000"
